{
	"info": {
		"_postman_id": "scanpet-api-collection",
		"name": "ScanPet Mobile Backend API",
		"description": "Complete API collection for ScanPet Backend with .NET 8\nBase URL: http://localhost:5000\n\nUsers:\n- admin / Admin@123 (Full Access)\n- manager / Manager@123 (Operational)\n- user / User@123 (View Only)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{accessToken}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5000",
			"type": "string"
		},
		{
			"key": "accessToken",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Login - Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('accessToken', jsonData.data.accessToken);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin@123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "login"]
						}
					}
				},
				{
					"name": "Login - Manager",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"manager\",\n  \"password\": \"Manager@123\"\n}"
						},
						"url": "{{baseUrl}}/api/auth/login"
					}
				},
				{
					"name": "Login - User",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"user\",\n  \"password\": \"User@123\"\n}"
						},
						"url": "{{baseUrl}}/api/auth/login"
					}
				},
				{
					"name": "Register New User",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"newuser\",\n  \"email\": \"newuser@example.com\",\n  \"password\": \"NewUser@123\",\n  \"fullName\": \"New User\",\n  \"phoneNumber\": \"+1234567893\"\n}"
						},
						"url": "{{baseUrl}}/api/auth/register"
					}
				},
				{
					"name": "Refresh Token",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refreshToken\": \"your_refresh_token_here\"\n}"
						},
						"url": "{{baseUrl}}/api/auth/refresh"
					}
				}
			]
		},
		{
			"name": "Users",
			"item": [
				{
					"name": "Get All Users",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/users?pageNumber=1&pageSize=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "users"],
							"query": [
								{"key": "pageNumber", "value": "1"},
								{"key": "pageSize", "value": "10"}
							]
						}
					}
				},
				{
					"name": "Get User By ID",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/api/users/{{userId}}"
					}
				},
				{
					"name": "Create User",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"Test@123\",\n  \"fullName\": \"Test User\",\n  \"phoneNumber\": \"+1234567894\"\n}"
						},
						"url": "{{baseUrl}}/api/users"
					}
				},
				{
					"name": "Update User",
					"request": {
						"method": "PUT",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"updated@example.com\",\n  \"fullName\": \"Updated Name\",\n  \"phoneNumber\": \"+1234567895\"\n}"
						},
						"url": "{{baseUrl}}/api/users/{{userId}}"
					}
				},
				{
					"name": "Approve User",
					"request": {
						"method": "PUT",
						"url": "{{baseUrl}}/api/users/{{userId}}/approve"
					}
				}
			]
		},
