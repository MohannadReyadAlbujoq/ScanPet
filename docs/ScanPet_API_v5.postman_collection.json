        { "name": "Confirm Order", "request": { "method": "PUT", "header": [], "url": { "raw": "{{baseUrl}}/api/orders/{{orderId}}/confirm", "host": ["{{baseUrl}}"], "path": ["api","orders","{{orderId}}","confirm"] } } },
        { "name": "Cancel Order", "request": { "method": "PUT", "header": [], "url": { "raw": "{{baseUrl}}/api/orders/{{orderId}}/cancel?reason=Out of stock", "host": ["{{baseUrl}}"], "path": ["api","orders","{{orderId}}","cancel"], "query": [{ "key": "reason", "value": "Out of stock" }] } } },
