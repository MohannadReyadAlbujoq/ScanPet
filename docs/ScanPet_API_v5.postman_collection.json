        { "name": "Set Item Inventory", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"itemId\": \"{{itemId}}\",\n  \"inventoryId\": \"{{inventoryId}}\",\n  \"quantity\": 100,\n  \"minimumQuantity\": 10,\n  \"maximumQuantity\": 500,\n  \"notes\": \"Initial stock\"\n}" }, "url": { "raw": "{{baseUrl}}/api/inventories/items", "host": ["{{baseUrl}}"], "path": ["api","inventories","items"] } } },
        { "name": "Update Item Quantity (PUT)", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"itemId\": \"{{itemId}}\",\n  \"inventoryId\": \"{{inventoryId}}\",\n  \"quantity\": 100,\n  \"minimumQuantity\": 10,\n  \"maximumQuantity\": 500,\n  \"notes\": \"Updated stock\"\n}" }, "url": { "raw": "{{baseUrl}}/api/inventories/items", "host": ["{{baseUrl}}"], "path": ["api","inventories","items"] } } },
        { "name": "Increment Inventory", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"itemId\": \"{{itemId}}\",\n  \"inventoryId\": \"{{inventoryId}}\",\n  \"quantity\": 10,\n  \"notes\": \"Restocking\",\n  \"reason\": \"Weekly supply delivery\"\n}" }, "url": { "raw": "{{baseUrl}}/api/inventories/increment", "host": ["{{baseUrl}}"], "path": ["api","inventories","increment"] } } },
        { "name": "Decrement Inventory", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"itemId\": \"{{itemId}}\",\n  \"inventoryId\": \"{{inventoryId}}\",\n  \"quantity\": 1,\n  \"notes\": \"Manual removal\",\n  \"reason\": \"Damaged goods\"\n}" }, "url": { "raw": "{{baseUrl}}/api/inventories/decrement", "host": ["{{baseUrl}}"], "path": ["api","inventories","decrement"] } } },
        { "name": "Adjust Inventory", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"itemId\": \"{{itemId}}\",\n  \"inventoryId\": \"{{inventoryId}}\",\n  \"quantityChange\": -5,\n  \"notes\": \"Damaged goods removed\",\n  \"reason\": \"Quality control\"\n}" }, "url": { "raw": "{{baseUrl}}/api/inventories/adjust", "host": ["{{baseUrl}}"], "path": ["api","inventories","adjust"] } } },
