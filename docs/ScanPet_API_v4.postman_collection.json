            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser\",\n  \"email\": \"newuser@example.com\",\n  \"password\": \"NewUser@123\",\n  \"confirmPassword\": \"NewUser@123\",\n  \"fullName\": \"New User\",\n  \"phoneNumber\": \"+962791234567\",\n  \"defaultInventoryIds\": [],\n  \"defaultLocationIds\": []\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "auth": { "type": "noauth" },
            "description": "v4: Accepts optional `defaultInventoryIds` and `defaultLocationIds` arrays"
          }
        },
