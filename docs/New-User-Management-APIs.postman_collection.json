	"item": [
		{
			"name": "1. Get All Roles",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{accessToken}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/api/roles",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"roles"
					]
				},
				"description": "Get all roles with their permissions. This endpoint returns a list of all roles in the system including:\n- Role ID\n- Role Name\n- Description\n- Permissions Bitmask\n- List of Permission Names\n- User Count (how many users have this role)\n- Created Date"
			},
