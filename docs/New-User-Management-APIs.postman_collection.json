		{
			"name": "3. Toggle User Status (Enable/Disable)",
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{accessToken}}",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"isEnabled\": false\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/api/users/{{userId}}/status",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"users",
						"{{userId}}",
						"status"
					]
				},
				"description": "Enable or disable a user account. When disabling a user:\n- User account is marked as disabled\n- All active refresh tokens are revoked\n- User cannot login until re-enabled\n- Cannot disable your own account\n\n**Request Body:**\n- `isEnabled` (required): true to enable, false to disable\n\n**Path Parameters:**\n- `userId` (required): GUID of the user to update"
			},
