{
  "info": {
    "name": "ScanPet Mobile Backend API",
    "description": "Complete API collection for ScanPet Mobile Backend.\n\nDefault credentials:\n- Admin: admin / Admin@123\n- Manager: manager / Manager@123\n- User: user / User@123\n\nAll endpoints (except auth) require Bearer token in Authorization header.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://scanpet-production.up.railway.app", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" },
    { "key": "roleId", "value": "", "type": "string" },
    { "key": "colorId", "value": "", "type": "string" },
    { "key": "itemId", "value": "", "type": "string" },
