          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] },
            "description": "v2: Now fetches full user from DB. Returns userId, username, email, fullName, phoneNumber, isAuthenticated, isEnabled, isApproved, defaultInventoryId, defaultInventoryName, roles[]"
          }
        }
