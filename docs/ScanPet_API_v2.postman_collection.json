{
  "info": {
    "name": "ScanPet Mobile Backend API v2",
    "description": "Complete API collection for ScanPet Mobile Backend v2.\n\nChanges in v2:\n- Items: File upload support (multipart/form-data) for create/update\n- Items: Enriched response with totalCount, colorHexCode, lastUpdatedInventoryName, lastUpdatedInventoryDate\n- Inventory Items: Now includes itemImageUrl, itemBasePrice, colorName, colorHexCode\n- Users: Default inventory support (defaultInventoryId, defaultInventoryName)\n- Auth: /me endpoint returns full user info including defaultInventoryId and roles\n- Auth: Login/refresh responses include defaultInventoryId in user info\n- Orders: Status filter on GET /api/orders (?status=0|1|2)\n- Orders: Refund details (refundedQuantity, refundedAmount, refundReason, refundedAt) in order item responses\n- Items Update: Fixed 500 error on PUT /api/items/{id}\n\nDefault credentials:\n- Admin: admin / Admin@123\n- Manager: manager / Manager@123\n- User: user / User@123\n\nAll endpoints (except auth) require Bearer token in Authorization header.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://scanpet-production.up.railway.app", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" },
    { "key": "roleId", "value": "", "type": "string" },
    { "key": "colorId", "value": "", "type": "string" },
    { "key": "itemId", "value": "", "type": "string" },
    { "key": "locationId", "value": "", "type": "string" },
    { "key": "orderId", "value": "", "type": "string" },
    { "key": "inventoryId", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] },
            "auth": { "type": "noauth" }
          }
        }
      ]
    },
