<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.nlog-project.org/schemas/NLog.xsd NLog.xsd"
      autoReload="true"
      throwExceptions="false"
      throwConfigExceptions="true"
      internalLogLevel="Off"
      internalLogFile="c:\temp\nlog-internal.log">

  <!-- 
    ===================================================================
    NLog Configuration for ScanPet Mobile Backend API
    ===================================================================
    
    This configuration provides:
    - HTML logs with interactive filtering and search
    - Automatic file rotation based on size (5 MB per file)
    - Archive management (max 100 files, ~500 MB total)
    - Separate error logs for quick troubleshooting
    - Console output for development
    - Text backup logs
    
    Log Files Location: C:\AppLogs\ScanPet\
    Archive Location: C:\AppLogs\ScanPet\Archive\
    
    ===================================================================
  -->

  <!-- Load custom extensions -->
  <extensions>
    <add assembly="NLog.Web.AspNetCore"/>
    <add assembly="MobileBackend.API"/>
  </extensions>

  <!-- Configuration Variables -->
  <variable name="logDirectory" value="C:\AppLogs\ScanPet\"/>
  <variable name="archiveDirectory" value="C:\AppLogs\ScanPet\Archive\"/>
  
  <!-- File size limits (in bytes) -->
  <variable name="maxFileSize" value="5000000"/>      <!-- 5 MB -->
  <variable name="maxArchiveFiles" value="100"/>       <!-- ~500 MB total -->
  
  <!-- Log format for text files -->
  <variable name="standardLayout" value="${longdate}|${level:uppercase=true}|${logger:shortName=true}|${message}${onexception:${newline}EXCEPTION\: ${exception:format=tostring}}"/>
  
  <!-- Detailed layout with context -->
  <variable name="detailedLayout" value="${longdate}|${level:uppercase=true}|${logger}|${aspnet-user-identity}|${aspnet-request-url}|${message}${onexception:${newline}${exception:format=tostring}}"/>

  <!-- Targets Configuration -->
  <targets async="true">
    
    <!-- ============================================ -->
    <!-- PRIMARY: HTML Log with Interactive Filtering -->
    <!-- ============================================ -->
    <target xsi:type="AsyncWrapper" 
            name="htmlLogger" 
            overflowAction="Grow"
            queueLimit="10000"
            batchSize="100"
            timeToSleepBetweenBatches="50">
      <target xsi:type="HtmlLog" 
              name="htmlFile" 
              fileName="${logDirectory}log.html"
              archiveFileName="${archiveDirectory}log.{#}.html"
              archiveAboveSize="${maxFileSize}"
              maxArchiveFiles="${maxArchiveFiles}"
              archiveDateFormat="yyyy-MM-dd" />
    </target>

    <!-- ============================================ -->
    <!-- SECONDARY: Error-Only Log (Quick Debug) -->
    <!-- ============================================ -->
    <target xsi:type="File"
            name="errorFile"
            fileName="${logDirectory}errors-${shortdate}.log"
            archiveFileName="${archiveDirectory}errors.{#}.log"
            archiveNumbering="DateAndSequence"
            archiveAboveSize="${maxFileSize}"
            maxArchiveFiles="50"
            archiveDateFormat="yyyy-MM-dd"
            layout="${detailedLayout}"
            encoding="utf-8"
            keepFileOpen="false" />
    
    <!-- ============================================ -->
    <!-- BACKUP: Text Log (Plain Text Backup) -->
    <!-- ============================================ -->
    <target xsi:type="File"
            name="textFile"
            fileName="${logDirectory}log-${shortdate}.txt"
            archiveFileName="${archiveDirectory}log-text.{#}.txt"
            archiveNumbering="DateAndSequence"
            archiveAboveSize="${maxFileSize}"
            maxArchiveFiles="${maxArchiveFiles}"
            archiveDateFormat="yyyy-MM-dd"
            layout="${standardLayout}"
            encoding="utf-8"
            keepFileOpen="false" />

    <!-- ============================================ -->
    <!-- CONSOLE: Development Output -->
    <!-- ============================================ -->
    <target xsi:type="ColoredConsole" 
            name="console"
            layout="${standardLayout}">
      <highlight-row condition="level == LogLevel.Error" foregroundColor="Red" />
      <highlight-row condition="level == LogLevel.Warn" foregroundColor="Yellow" />
      <highlight-row condition="level == LogLevel.Info" foregroundColor="Green" />
      <highlight-row condition="level == LogLevel.Debug" foregroundColor="Gray" />
      <highlight-row condition="level == LogLevel.Trace" foregroundColor="DarkGray" />
    </target>
    
    <!-- ============================================ -->
    <!-- AUDIT: Separate Audit Trail (Optional) -->
    <!-- ============================================ -->
    <target xsi:type="File"
            name="auditFile"
            fileName="${logDirectory}audit-${shortdate}.log"
            archiveFileName="${archiveDirectory}audit.{#}.log"
            archiveNumbering="DateAndSequence"
            archiveAboveSize="${maxFileSize}"
            maxArchiveFiles="365"
            archiveDateFormat="yyyy-MM-dd"
            layout="${detailedLayout}"
            encoding="utf-8"
            keepFileOpen="false" />

  </targets>

  <!-- Logging Rules -->
  <rules>
    <!-- 
      ============================================
      PRIMARY RULES: Application Logging
      ============================================
    -->
    
    <!-- Log all application logs to HTML (Trace and above) -->
    <logger name="MobileBackend.*" minlevel="Trace" writeTo="htmlLogger" />
    <logger name="MobileBackend.API.Logging.*" minlevel="Trace" writeTo="htmlLogger" />
    
    <!-- Log all errors to separate error file -->
    <logger name="*" minlevel="Error" writeTo="errorFile" />
    
    <!-- Log Info and above to text backup -->
    <logger name="*" minlevel="Info" writeTo="textFile" />
    
    <!-- Console logging for development (Info and above) -->
    <logger name="*" minlevel="Info" writeTo="console" />
    
    <!-- 
      ============================================
      AUDIT LOGGING: Security & Business Events
      ============================================
    -->
    <logger name="MobileBackend.API.Middleware.AuditLoggingMiddleware" minlevel="Info" writeTo="auditFile" />
    <logger name="MobileBackend.Application.Features.Auth.*" minlevel="Info" writeTo="auditFile" />
    
    <!-- 
      ============================================
      NOISE REDUCTION: Filter Out Verbose Logs
      ============================================
    -->
    
    <!-- Suppress Microsoft framework logs unless Warning or above -->
    <logger name="Microsoft.*" maxlevel="Info" final="true" />
    <logger name="Microsoft.EntityFrameworkCore.*" maxlevel="Warning" final="true" />
    <logger name="Microsoft.AspNetCore.*" maxlevel="Warning" final="true" />
    
    <!-- Suppress System logs unless Warning or above -->
    <logger name="System.Net.Http.*" maxlevel="Warning" final="true" />
    <logger name="System.Threading.*" maxlevel="Warning" final="true" />
    
    <!-- 
      ============================================
      CATCH-ALL: Anything not caught above
      ============================================
    -->
    <logger name="*" minlevel="Warn" writeTo="textFile" />
  </rules>
  
  <!--
    ===================================================================
    TROUBLESHOOTING
    ===================================================================
    
    If logs are not appearing:
    1. Check internal log: c:\temp\nlog-internal.log
    2. Enable internal logging by setting:
       internalLogLevel="Debug"
    3. Verify directory permissions for C:\AppLogs\ScanPet\
    4. Ensure custom HtmlLog target is being loaded
    
    Performance tuning:
    - Increase batchSize if many logs per second
    - Adjust timeToSleepBetweenBatches for throughput
    - Increase queueLimit if seeing overflow warnings
    
    ===================================================================
  -->
</nlog>
