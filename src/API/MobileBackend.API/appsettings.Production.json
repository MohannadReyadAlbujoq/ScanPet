{
  "ConnectionStrings": {
    "DefaultConnection": "${DATABASE_URL}"
  },
  "DatabaseProvider": "PostgreSQL",
  "JwtSettings": {
    "PrivateKey": "${JWT_PRIVATE_KEY}",
    "PublicKey": "${JWT_PUBLIC_KEY}",
    "Issuer": "MobileBackendAPI",
    "Audience": "MobileApp",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "SecuritySettings": {
    "EnableBitManipulation": true,
    "EnableRsaEncryption": true,
    "PasswordRequirements": {
      "MinimumLength": 12,
      "MaximumLength": 128,
      "RequireUppercase": true,
      "RequireLowercase": true,
      "RequireDigit": true,
      "RequireSpecialCharacter": true
    },
    "MaxLoginAttempts": 3,
    "LockoutDurationMinutes": 30
  },
  "NLogSettings": {
    "EnableHtmlLogging": false,
    "LogDirectory": "/app/logs/",
    "ArchiveDirectory": "/app/logs/archive/",
    "MaxFileSize": 5000000,
    "MaxArchiveFiles": 10,
    "LogLevel": "Info"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": ["*"],
    "AllowedMethods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
    "AllowedHeaders": ["*"],
    "AllowCredentials": true
  },
  "ApiSettings": {
    "EnableSwagger": false,
    "EnableCompression": true,
    "EnableRateLimiting": true,
    "RateLimitPerMinute": 100,
    "PageSizeDefault": 20,
    "PageSizeMax": 50
  },
  "FileStorage": {
    "Provider": "Local",
    "LocalPath": "/var/data/uploads",
    "MaxFileSizeMB": 10,
    "AllowedExtensions": [
      ".jpg",
      ".jpeg",
      ".png",
      ".gif",
      ".pdf"
    ]
  },
  "Email": {
    "Provider": "Smtp",
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "SmtpUsername": "FROM_ENV_VAR",
    "SmtpPassword": "FROM_ENV_VAR",
    "FromEmail": "noreply@mobilebackend.com",
    "FromName": "Mobile Backend",
    "EnableSsl": true
  },
  "Caching": {
    "Provider": "Memory",
    "DefaultExpirationMinutes": 60,
    "CacheProfiles": {
      "Colors": 1440,
      "Locations": 1440,
      "Permissions": 60,
      "UserPermissions": 15
    }
  },
  "AuditLogging": {
    "EnableAuditLogs": true,
    "LogSuccessfulLogins": true,
    "LogFailedLogins": true,
    "LogDataModifications": true,
    "LogPermissionChanges": true,
    "BatchSize": 500,
    "BatchIntervalSeconds": 10
  },
  "BackgroundJobs": {
    "EnableHangfire": false,
    "HangfireDashboardPath": "/hangfire",
    "CleanupExpiredTokensEnabled": true,
    "CleanupIntervalHours": 24
  }
}
